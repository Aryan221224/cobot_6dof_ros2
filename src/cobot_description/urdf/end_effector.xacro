<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       DUAL-MODE END EFFECTOR
       Mode A: 2-finger parallel gripper (industrial tasks)
       Mode B: Motorised pipette (lab automation / surgical)

       Both are always present in URDF (mode switching done in
       software via active joint enabling). Quick-swap mount
       modelled as fixed joint at tool_flange.
       ============================================================ -->

  <xacro:macro name="dual_end_effector" params="parent">

    <!-- ── QUICK-SWAP MOUNT ──────────────────────────────────── -->
    <joint name="quickswap_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="quickswap_mount"/>
      <origin xyz="0 0 0.012" rpy="0 0 0"/>
    </joint>

    <link name="quickswap_mount">
      <visual>
        <origin xyz="0 0 0.006" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.012" radius="0.026"/>
        </geometry>
        <material name="gripper_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.006" rpy="0 0 0"/>
        <geometry><cylinder length="0.012" radius="0.026"/></geometry>
      </collision>
      <inertial>
        <mass value="0.08"/>
        <inertia ixx="0.00002" iyy="0.00002" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── GRIPPER PALM ──────────────────────────────────────── -->
    <joint name="gripper_palm_joint" type="fixed">
      <parent link="quickswap_mount"/>
      <child link="gripper_palm"/>
      <origin xyz="0 0 0.012" rpy="0 0 0"/>
    </joint>

    <link name="gripper_palm">
      <visual>
        <origin xyz="0 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.060 0.040 0.040"/>
        </geometry>
        <material name="gripper_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.020" rpy="0 0 0"/>
        <geometry><box size="0.060 0.040 0.040"/></geometry>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── GRIPPER FINGER LEFT ──────────────────────────────── -->
    <joint name="gripper_left_joint" type="prismatic">
      <parent link="gripper_palm"/>
      <child link="gripper_finger_left"/>
      <origin xyz="-0.015 0 0.040" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.025" upper="0.000" effort="20.0" velocity="0.05"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>

    <link name="gripper_finger_left">
      <visual>
        <origin xyz="-0.012 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.012 0.018 0.040"/>
        </geometry>
        <material name="gripper_grey"/>
      </visual>
      <collision>
        <origin xyz="-0.012 0 0.020" rpy="0 0 0"/>
        <geometry><box size="0.012 0.018 0.040"/></geometry>
      </collision>
      <inertial>
        <mass value="0.04"/>
        <inertia ixx="0.000005" iyy="0.000005" izz="0.000005" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- Finger left tip (rubber pad) -->
    <joint name="finger_left_tip_joint" type="fixed">
      <parent link="gripper_finger_left"/>
      <child link="finger_left_tip"/>
      <origin xyz="-0.018 0 0.010" rpy="0 0 0"/>
    </joint>

    <link name="finger_left_tip">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.006 0.016 0.020"/></geometry>
        <material name="gripper_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.006 0.016 0.020"/></geometry>
      </collision>
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── GRIPPER FINGER RIGHT ─────────────────────────────── -->
    <joint name="gripper_right_joint" type="prismatic">
      <parent link="gripper_palm"/>
      <child link="gripper_finger_right"/>
      <origin xyz="0.015 0 0.040" rpy="0 0 0"/>
      <axis xyz="-1 0 0"/>
      <limit lower="-0.025" upper="0.000" effort="20.0" velocity="0.05"/>
      <dynamics damping="0.5" friction="0.1"/>
      <mimic joint="gripper_left_joint" multiplier="1.0" offset="0.0"/>
    </joint>

    <link name="gripper_finger_right">
      <visual>
        <origin xyz="0.012 0 0.020" rpy="0 0 0"/>
        <geometry>
          <box size="0.012 0.018 0.040"/>
        </geometry>
        <material name="gripper_grey"/>
      </visual>
      <collision>
        <origin xyz="0.012 0 0.020" rpy="0 0 0"/>
        <geometry><box size="0.012 0.018 0.040"/></geometry>
      </collision>
      <inertial>
        <mass value="0.04"/>
        <inertia ixx="0.000005" iyy="0.000005" izz="0.000005" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="finger_right_tip_joint" type="fixed">
      <parent link="gripper_finger_right"/>
      <child link="finger_right_tip"/>
      <origin xyz="0.018 0 0.010" rpy="0 0 0"/>
    </joint>

    <link name="finger_right_tip">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.006 0.016 0.020"/></geometry>
        <material name="gripper_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="0.006 0.016 0.020"/></geometry>
      </collision>
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ══════════════════════════════════════════════════════════
         PIPETTE MODULE — Full spec implementation
         Components:
           1. Z-axis linear actuator  (pipette_z_joint)   ← NEW
           2. Pipette body + plunger motor
           3. Tip (seated / ejected states)
           4. Tip ejector mechanism   (pipette_eject_joint) ← NEW
         ══════════════════════════════════════════════════════════ -->

    <!-- ── PIPETTE Z-AXIS LINEAR ACTUATOR ───────────────────────
         Moves the entire pipette assembly up/down independently
         of the arm. Gives fine Z control for well-plate work
         without disturbing the arm's joint configuration.
         Travel: 30 mm  |  Force: 10 N  |  Speed: 20 mm/s      -->
    <joint name="pipette_z_joint" type="prismatic">
      <parent link="gripper_palm"/>
      <child link="pipette_z_carriage"/>
      <origin xyz="0 0.028 0.005" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.030" upper="0.000" effort="10.0" velocity="0.020"/>
      <dynamics damping="0.8" friction="0.05"/>
    </joint>

    <!-- Z-carriage (structural housing for the linear actuator) -->
    <link name="pipette_z_carriage">
      <visual>
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
        <geometry>
          <box size="0.022 0.014 0.024"/>
        </geometry>
        <material name="gripper_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
        <geometry><box size="0.022 0.014 0.024"/></geometry>
      </collision>
      <inertial>
        <mass value="0.025"/>
        <inertia ixx="0.000005" iyy="0.000005" izz="0.000002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── PIPETTE BODY (mounted on Z-carriage) ─────────────── -->
    <joint name="pipette_body_joint" type="fixed">
      <parent link="pipette_z_carriage"/>
      <child link="pipette_body"/>
      <origin xyz="0 0 0.024" rpy="0 0 0"/>
    </joint>

    <link name="pipette_body">
      <visual>
        <origin xyz="0 0 0.040" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.080" radius="0.008"/>
        </geometry>
        <material name="pipette_white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.040" rpy="0 0 0"/>
        <geometry><cylinder length="0.080" radius="0.008"/></geometry>
      </collision>
      <inertial>
        <mass value="0.030"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.000002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── PLUNGER MOTOR (aspirate / dispense) ──────────────────
         Prismatic joint models the piston displacement.
         +Z = retract (aspirate liquid into tip)
         -Z = extend  (dispense liquid from tip)
         Travel: ±20 mm → maps to ~200 µL at standard tip geometry -->
    <joint name="pipette_plunger_joint" type="prismatic">
      <parent link="pipette_body"/>
      <child link="pipette_plunger"/>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.020" upper="0.000" effort="5.0" velocity="0.010"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <link name="pipette_plunger">
      <visual>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.010" radius="0.007"/>
        </geometry>
        <material name="cobot_accent"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.005" rpy="0 0 0"/>
        <geometry><cylinder length="0.010" radius="0.007"/></geometry>
      </collision>
      <inertial>
        <mass value="0.008"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── PIPETTE TIP (seated position) ────────────────────────
         Represents a standard 200 µL polypropylene tip.
         Amber/yellow colour matches common lab tip convention.  -->
    <joint name="pipette_tip_joint" type="fixed">
      <parent link="pipette_body"/>
      <child link="pipette_tip"/>
      <origin xyz="0 0 0.000" rpy="0 0 0"/>
    </joint>

    <link name="pipette_tip">
      <visual>
        <origin xyz="0 0 -0.022" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.044" radius="0.004"/>
        </geometry>
        <material name="pipette_tip"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.022" rpy="0 0 0"/>
        <geometry><cylinder length="0.044" radius="0.004"/></geometry>
      </collision>
      <inertial>
        <mass value="0.004"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── TIP EJECTOR MECHANISM ─────────────────────────────────
         A prismatic ring that slides down the pipette barrel to
         physically knock the used tip off the cone.
         This is the "tip eject" function — modelled as a collar
         that translates downward against the tip flange.
         Travel: 12 mm  |  Force: 8 N (enough to break tip seat) -->
    <joint name="pipette_eject_joint" type="prismatic">
      <parent link="pipette_body"/>
      <child link="tip_ejector_collar"/>
      <origin xyz="0 0 0.002" rpy="0 0 0"/>
      <axis xyz="0 0 -1"/>
      <limit lower="0.000" upper="0.012" effort="8.0" velocity="0.050"/>
      <dynamics damping="0.3" friction="0.02"/>
    </joint>

    <link name="tip_ejector_collar">
      <visual>
        <origin xyz="0 0 -0.004" rpy="0 0 0"/>
        <geometry>
          <!-- Ring collar: outer radius slightly larger than body -->
          <cylinder length="0.008" radius="0.011"/>
        </geometry>
        <material name="gripper_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.004" rpy="0 0 0"/>
        <geometry><cylinder length="0.008" radius="0.011"/></geometry>
      </collision>
      <inertial>
        <mass value="0.006"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── PIPETTE TCP (liquid contact point) -->
    <joint name="pipette_tcp_joint" type="fixed">
      <parent link="pipette_tip"/>
      <child link="pipette_tcp"/>
      <origin xyz="0 0 0.036" rpy="0 0 0"/>
    </joint>

    <link name="pipette_tcp">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── TIP DETECTION SENSOR (optical, on palm) ───────────── -->
    <!-- Models the IR presence sensor that confirms tip is seated -->
    <joint name="tip_sensor_joint" type="fixed">
      <parent link="gripper_palm"/>
      <child link="tip_sensor"/>
      <origin xyz="0 0.028 0.085" rpy="0 0 0"/>
    </joint>

    <link name="tip_sensor">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.003"/></geometry>
        <material name="red_indicator"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.003"/></geometry>
      </collision>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ── MODE 3: SURGICAL TOOL MOCK (Articulus style) ─────── -->
    <!-- Detachable surgical instrument: dissector / cautery dummy -->
    <!-- Mounted on opposite side of palm from pipette (Y negative) -->
    <joint name="surgical_tool_joint" type="fixed">
      <parent link="gripper_palm"/>
      <child link="surgical_tool_body"/>
      <origin xyz="0 -0.028 0.005" rpy="0 0 0"/>
    </joint>

    <link name="surgical_tool_body">
      <visual>
        <origin xyz="0 0 0.042" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.084" radius="0.006"/>
        </geometry>
        <material name="cobot_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.042" rpy="0 0 0"/>
        <geometry><cylinder length="0.084" radius="0.006"/></geometry>
      </collision>
      <inertial>
        <mass value="0.025"/>
        <inertia ixx="0.00001" iyy="0.00001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- Surgical jaw — proximal link -->
    <joint name="surgical_jaw_joint" type="revolute">
      <parent link="surgical_tool_body"/>
      <child link="surgical_jaw"/>
      <origin xyz="0 0 0.084" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.30" upper="0.30" effort="5.0" velocity="0.5"/>
      <dynamics damping="0.05" friction="0.01"/>
    </joint>

    <link name="surgical_jaw">
      <visual>
        <origin xyz="0 0 0.010" rpy="0 0 0"/>
        <geometry>
          <box size="0.003 0.010 0.020"/>
        </geometry>
        <material name="cobot_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.010" rpy="0 0 0"/>
        <geometry><box size="0.003 0.010 0.020"/></geometry>
      </collision>
      <inertial>
        <mass value="0.005"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- Surgical tool TCP -->
    <joint name="surgical_tcp_joint" type="fixed">
      <parent link="surgical_jaw"/>
      <child link="surgical_tcp"/>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
    </joint>

    <link name="surgical_tcp">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- Cautery activation indicator (LED mock — green sphere) -->
    <joint name="cautery_led_joint" type="fixed">
      <parent link="surgical_tool_body"/>
      <child link="cautery_led"/>
      <origin xyz="0 0 0.010" rpy="0 0 0"/>
    </joint>

    <link name="cautery_led">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.003"/></geometry>
        <material name="green_indicator"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.003"/></geometry>
      </collision>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.000001" iyy="0.000001" izz="0.000001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

  </xacro:macro>

</robot>
